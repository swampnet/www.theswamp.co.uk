@page "/wines/{id:long}"
@rendermode InteractiveServer
@inject TheSwamp.WWW.Services.IWineService _wine;
@inject TheSwamp.WWW.Services.IAIService _ai;
@inject TheSwamp.WWW.Services.IChatService _chat;


@if(_details == null)
{
    <h3>loading</h3>
}
else
{
    <h3>🍷@_details.Name</h3>
    <p>Produced by @_details.Producer in @_details.Region, @_details.Country</p>
    <div class="review">
        <div class="review-text">
            @if (string.IsNullOrWhiteSpace(_reviewText))
            {
                <span>✨ generating review...</span>
            }
            @((MarkupString)_review)
        </div>
    </div>

    <RandomWineButton/>

    <div class="disclaimer">
        Generated by an AI. Opinions are its own and generally pretty random. Please don't sue me.
    </div>

    <table class="table table-sm" style="font-size:0.8em">
        <thead>
            <tr>
                <th>Id</th>
                <th>Description</th>
                <th>Producer</th>
                <th>Country</th>
                <th>Region</th>
                <th>Colour</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@_details.Id</td>
                <td>@_details.Display</td>
                <td>@_details.Producer</td>
                <td>@_details.Country</td>
                <td>@_details.Region</td>
                <td>@_details.Colour</td>
            </tr>
        </tbody>
    </table>


}

@code {
    [Parameter]
    public long Id { get; set; }

    private WineDto? _details;
    private string _reviewText = "";
    private string _review = "";
    private bool _streamingStarted = false;
    private string _length = "short";

    protected override async Task OnInitializedAsync()
    {
        _details = await _wine.Details(Id);
        _ai.SetSystemPrompt($"You are a professional wine reviewer. Output plain text only, no markdown.");
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!RendererInfo.IsInteractive || _streamingStarted || _details is null)
        {
            return;
        }

        _streamingStarted = true;

        var prompt = $"Write a {_length} review of this {_details.Type} '{_details.Display}' color: {_details.Colour}, producer: {_details.Producer}, country: {_details.Country}, region: {_details.Region}. Avoid repeating the name of the wine in the review.";
        
        //prompt += "Make it rhyme";

        await foreach (var token in _ai.StreamAsync(prompt))
        {
            _reviewText += token;
            _review = _reviewText.Replace(". ", ".<br>");
            await InvokeAsync(StateHasChanged);
        }

        await _chat.SendMessageAsync(null, $"Reviewed {_details.Display}");
    }
}
