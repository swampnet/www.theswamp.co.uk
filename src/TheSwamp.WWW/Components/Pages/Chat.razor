@page "/chat"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject TheSwamp.WWW.Services.IChatService ChatService
@inject TheSwamp.WWW.Services.IConnectionTracker ConnectionTracker
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Chat</PageTitle>

<h2>Chat</h2>
<p>Simple chat client using SignalR</p>

<div id="chat-messages" style="height:400px; overflow-y:auto; border:1px solid #ccc; padding:8px; margin-bottom:8px;">
    @foreach (var msg in _messages)
    {
        <div>
            <strong>@msg.DisplayName</strong>
            <span style="color:#999; font-size:0.85em;">@msg.SentOnUtc.ToLocalTime().ToString("HH:mm")</span>:
            @msg.Text
        </div>
    }
</div>

<div style="display:flex; gap:8px;">
    <input @bind="_messageText" @bind:event="oninput" @onkeydown="OnKeyDown"
           placeholder="Type a message..." style="flex:1;" maxlength="500" />
    <button @onclick="SendMessage" disabled="@(!CanSend)">Send</button>
</div>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <p style="color:#666; font-style:italic; margin-top:4px;">@_statusMessage</p>
}

@if (_isAdmin)
{
    <hr />
    <h4>Connected Users (@_connectedUsers.Count)</h4>
    <table style="width:100%; font-size:0.85em; border-collapse:collapse;">
        <thead>
            <tr style="text-align:left; border-bottom:1px solid #ccc;">
                <th style="padding:4px 8px;">Display Name</th>
                <th style="padding:4px 8px;">User ID</th>
                <th style="padding:4px 8px;">Connection ID</th>
                <th style="padding:4px 8px;">IP Address</th>
                <th style="padding:4px 8px;">Connected At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conn in _connectedUsers)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:4px 8px;">@conn.DisplayName</td>
                    <td style="padding:4px 8px; font-family:monospace;">@(conn.UserId ?? "—")</td>
                    <td style="padding:4px 8px; font-family:monospace;">@conn.ConnectionId</td>
                    <td style="padding:4px 8px; font-family:monospace;">@conn.IpAddress</td>
                    <td style="padding:4px 8px;">@conn.ConnectedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // Simple local model for display — keeps display name alongside the other fields.
    private record DisplayMessage(string DisplayName, string Text, DateTime SentOnUtc);

    private readonly List<DisplayMessage> _messages = new();
    private HubConnection? _hubConnection;
    private IJSObjectReference? _jsModule;  // Lazy-loaded from Chat.razor.js; null until first render.
    private string _messageText = string.Empty;
    private string _statusMessage = string.Empty;
    private bool _scrollToBottom;    // Set after message load or a new message arrives — triggers a scroll to bottom on next render.

    /// <summary>
    /// The authenticated user's Identity ID, or null for anonymous visitors.
    /// Passed to the service so messages are stored with the correct UserId.
    /// </summary>
    private string? _userId;

    private bool _isAdmin;
    private IReadOnlyList<TheSwamp.WWW.Services.ConnectedUser> _connectedUsers = [];

    // Can send once the hub connection is open and there is text to send.
    private bool CanSend => _hubConnection?.State == HubConnectionState.Connected
                            && !string.IsNullOrWhiteSpace(_messageText);

    protected override async Task OnInitializedAsync()
    {
        // Extract the user ID from the NameIdentifier claim (the stable identity key).
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            _isAdmin = user.IsInRole("admin");
        }

        // Skip SignalR setup during server-side pre-render; it runs again interactively.
        if (!RendererInfo.IsInteractive)
        {
            return;
        }

        // Load recent message history directly via the service (no HTTP round-trip needed
        // because this component runs on the server and can call the service directly).
        await LoadRecentMessagesAsync();

        // OnAfterRenderAsync(firstRender=true) fires after the *first* render, which happens as
        // soon as OnInitializedAsync hits its first await — before messages are loaded. Setting
        // this flag here (after loading) ensures the scroll fires on the *next* render, when
        // the messages are actually in the DOM. The same flag is reused for incoming messages.
        _scrollToBottom = true;

        // Connect to the SignalR hub. Pass the userId as a query string param so the hub
        // can announce the correct display name on connect/disconnect for anon users.
        // Authenticated connections also benefit from Context.UserIdentifier on the hub side.
        var hubUrl = NavigationManager.ToAbsoluteUri(
            $"/hubs/chat?userId={Uri.EscapeDataString(_userId ?? string.Empty)}");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        // Handle incoming chat messages broadcast from any sender (API, hub, other pages).
        _hubConnection.On<string, string, string>("ReceiveMessage", (displayName, text, sentAtStr) =>
        {
            var sentAt = DateTime.TryParse(sentAtStr, out var dt) ? dt : DateTime.UtcNow;
            _messages.Add(new DisplayMessage(displayName, text, sentAt));
            RefreshConnectedUsers();
            // Set the scroll flag and call StateHasChanged together inside InvokeAsync so both
            // run on the Blazor sync context — ensures OnAfterRenderAsync sees the updated flag.
            InvokeAsync(() => { _scrollToBottom = true; StateHasChanged(); });
        });

        // Handle user-connected announcements.
        _hubConnection.On<string>("UserConnected", (displayName) =>
        {
            _messages.Add(new DisplayMessage("System", $"** {displayName} connected **", DateTime.UtcNow));
            RefreshConnectedUsers();
            InvokeAsync(() => { _scrollToBottom = true; StateHasChanged(); });
        });

        // Handle user-disconnected announcements.
        _hubConnection.On<string>("UserDisconnected", (displayName) =>
        {
            _messages.Add(new DisplayMessage("System", $"** {displayName} disconnected **", DateTime.UtcNow));
            RefreshConnectedUsers();
            InvokeAsync(() => { _scrollToBottom = true; StateHasChanged(); });
        });

        await _hubConnection.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Load the JS module once on the first interactive render.
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/Chat.razor.js");
        }

        if (_jsModule is null)
        {
            return;
        }

        // Scroll to the bottom after initial message load and after each new message.
        if (_scrollToBottom)
        {
            _scrollToBottom = false;
            await _jsModule.InvokeVoidAsync("scrollToBottom", "chat-messages");
        }
    }

    /// <summary>
    /// Loads recent message history from the database via the chat service.
    /// Display names are already resolved by the service; no UserManager needed here.
    /// </summary>
    private async Task LoadRecentMessagesAsync()
    {
        var recent = await ChatService.GetRecentMessagesAsync(50);
        foreach (var m in recent)
        {
            _messages.Add(new DisplayMessage(m.DisplayName, m.Text, m.SentOnUtc));
        }
    }

    /// <summary>
    /// Refreshes the connected users snapshot from the tracker.
    /// Called whenever a connect/disconnect/message event fires so the admin table stays current.
    /// </summary>
    private void RefreshConnectedUsers()
    {
        if (_isAdmin)
        {
            _connectedUsers = ConnectionTracker.GetConnectedUsers();
        }
    }

    /// <summary>
    /// Sends the current message via IChatService, which persists it to the database
    /// and broadcasts it to all connected SignalR clients (including this one).
    /// </summary>
    private async Task SendMessage()
    {
        if (!CanSend) { return; }

        var text = _messageText.Trim();
        _messageText = string.Empty;

        // Pass userId (null for anon); service resolves display name and broadcasts.
        await ChatService.SendMessageAsync(_userId, text);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // When the browser hard-refreshes (CTRL+F5), the circuit disconnects before
                // DisposeAsync completes, causing a JSDisconnectedException. This is expected
                // and safe to ignore — the JS runtime is already gone at this point.
            }
        }
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}