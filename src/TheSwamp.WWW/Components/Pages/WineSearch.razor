@page "/wine-search"
@rendermode InteractiveServer
@inject TheSwamp.WWW.Services.IWineSearchService _wineSearch;

<PageTitle>Wine Search</PageTitle>

<h3 class="mb-4">🍷 Wine Search</h3>
<p>Noddy LWIN wine search</p>
<div class="input-group mb-4">
    <input class="form-control"
           @bind="_term" @bind:event="oninput" @onkeydown="OnKeyDown"
           placeholder="Search by name, producer, region…"
           maxlength="100" />
    <button class="btn btn-primary" @onclick="Search" disabled="@(!CanSearch)">Search</button>
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Searching…</span>
        </div>
    </div>
}
else if (_results is not null)
{
    @if (_results.Count == 0)
    {
        <div class="alert alert-secondary">No wines found for "<strong>@_term</strong>".</div>
    }
    else
    {
        <p class="text-secondary small mb-2">
            <span class="badge bg-secondary me-1">@_results.Count</span> result@(_results.Count == 1 ? "" : "s")
        </p>

        <div class="table-responsive">
            <table class="table table-dark table-hover table-sm table-striped align-middle">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Producer</th>
                        <th>Country</th>
                        <th>Region</th>
                        <th>Colour</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wine in _results)
                    {
                        <tr>
                            <td>@wine.Display</td>
                            <td>@wine.Producer</td>
                            <td>@wine.Country</td>
                            <td>@wine.Region</td>
                            <td>
                                <span class="wine-badge @ColourBadgeClass(wine.Colour)">@wine.Colour</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private IReadOnlyCollection<WineDto>? _results = null;
    private string _term = "";
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
    }

    private bool CanSearch => !string.IsNullOrWhiteSpace(_term) && !_isLoading;

    private async Task Search()
    {
        _results = null;
        _isLoading = true;
        try
        {
            _results = await _wineSearch.Search(_term);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private static string ColourBadgeClass(string colour) => colour.ToLowerInvariant() switch
    {
        "red"                       => "wine-red",
        "white"                     => "wine-white",
        "rosé" or "rose"            => "wine-rose",
        "orange"                    => "wine-orange",
        "sparkling" or "champagne"  => "wine-sparkling",
        _                           => "wine-other",
    };
}
