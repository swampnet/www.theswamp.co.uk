@page "/chat"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject TheSwamp.WWW.Services.IChatService ChatService
@implements IAsyncDisposable

<PageTitle>Chat</PageTitle>

<h2>Chat</h2>

<div id="chat-messages" style="height:400px; overflow-y:auto; border:1px solid #ccc; padding:8px; margin-bottom:8px;">
    @foreach (var msg in _messages)
    {
        <div>
            <strong>@msg.UserName</strong>
            <span style="color:#999; font-size:0.85em;">@msg.SentAt.ToLocalTime().ToString("HH:mm")</span>:
            @msg.Text
        </div>
    }
</div>

<div style="display:flex; gap:8px;">
    <input @bind="_messageText" @bind:event="oninput" @onkeydown="OnKeyDown"
           placeholder="Type a message..." style="flex:1;" maxlength="500" />
    <button @onclick="SendMessage" disabled="@(!CanSend)">Send</button>
</div>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <p style="color:#666; font-style:italic; margin-top:4px;">@_statusMessage</p>
}

@code {
    // Simple local message model for display (not the DB entity).
    private record DisplayMessage(string UserName, string Text, DateTime SentAt);

    private readonly List<DisplayMessage> _messages = new();
    private HubConnection? _hubConnection;
    private string _messageText = string.Empty;
    private string _statusMessage = string.Empty;
    private string _userName = "Anon";

    // Can send once the hub connection is open and there is text to send.
    private bool CanSend => _hubConnection?.State == HubConnectionState.Connected
                            && !string.IsNullOrWhiteSpace(_messageText);

    protected override async Task OnInitializedAsync()
    {
        // Determine the display name from the auth state.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? "Anon";
        }

        // Skip SignalR setup during server-side pre-render; it runs again interactively.
        if (!RendererInfo.IsInteractive)
        {
            return;
        }

        // Load recent message history directly via the service (no HTTP round-trip needed
        // because this component runs on the server and can call the service directly).
        await LoadRecentMessagesAsync();

        // Connect to the SignalR hub using an absolute URI (required by HubConnectionBuilder).
        // The hub connection is used only for RECEIVING messages — sends go via IChatService.
        var hubUrl = NavigationManager.ToAbsoluteUri($"/hubs/chat?userName={Uri.EscapeDataString(_userName)}");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        // Handle incoming chat messages broadcast from any sender (API, hub, other pages).
        _hubConnection.On<string, string, string>("ReceiveMessage", (userName, text, sentAtStr) =>
        {
            var sentAt = DateTime.TryParse(sentAtStr, out var dt) ? dt : DateTime.UtcNow;
            _messages.Add(new DisplayMessage(userName, text, sentAt));
            InvokeAsync(StateHasChanged);
        });

        // Handle user-connected announcements.
        _hubConnection.On<string>("UserConnected", (userName) =>
        {
            _messages.Add(new DisplayMessage("System", $"** {userName} connected **", DateTime.UtcNow));
            InvokeAsync(StateHasChanged);
        });

        // Handle user-disconnected announcements.
        _hubConnection.On<string>("UserDisconnected", (userName) =>
        {
            _messages.Add(new DisplayMessage("System", $"** {userName} disconnected **", DateTime.UtcNow));
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    /// <summary>
    /// Loads recent message history from the database via the chat service and
    /// pre-populates the message list so the user can see prior conversation on arrival.
    /// </summary>
    private async Task LoadRecentMessagesAsync()
    {
        var recent = await ChatService.GetRecentMessagesAsync(50);
        foreach (var m in recent)
        {
            _messages.Add(new DisplayMessage(m.UserName, m.Text, m.SentOnUtc));
        }
    }

    /// <summary>
    /// Sends the current message via IChatService, which persists it to the database
    /// and broadcasts it to all connected SignalR clients (including this one).
    /// </summary>
    private async Task SendMessage()
    {
        if (!CanSend) { return; }

        var text = _messageText.Trim();
        _messageText = string.Empty;

        // Service handles DB persistence + SignalR broadcast.
        // The broadcast will trigger our own "ReceiveMessage" handler above,
        // which appends the message to the list — no need to add it manually here.
        await ChatService.SendMessageAsync(_userName, text);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}